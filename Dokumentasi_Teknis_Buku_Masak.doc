        }
        .note-box {
            background-color: #faf5ef;
            border-left: 4px solid #e76f51;
            padding: 15px;
            margin-top: 15px;
            margin-bottom: 15px;
        }
        .note-title {
            font-weight: bold;
            color: #e76f51;
            margin-bottom: 5px;
        }
        .code-snippet {
            font-family: 'Consolas', 'Courier New', monospace;
            background-color: #f4f4f4;
            padding: 10px;
            border: 1px solid #ddd;
